# Firebase configuration — copy to .env.local and fill in your project values.
# If any of the required fields (VITE_FIREBASE_API_KEY, VITE_FIREBASE_PROJECT_ID)
# are missing, the app falls back to LocalSync (single device only).
#
# Get these values from Firebase Console → Project Settings → General →
# "Your apps" → Web app → "SDK setup and configuration" → Config.
#
# After setting these, deploy the Firestore rules below so reads and writes
# work from the browser:
#
#   rules_version = '2';
#   service cloud.firestore {
#     match /databases/{database}/documents {
#       match /tournaments/{id} {
#         allow read, write: if true;
#       }
#     }
#   }
#
# (Rules above are wide open. Tighten them with Firebase Auth or a per-event
# passcode when you're ready to lock things down.)

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
